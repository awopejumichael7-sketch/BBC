rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin()   { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isTeacher() { return isSignedIn() && exists(/databases/$(database)/documents/teachers/$(request.auth.uid)); }
    function isStudent() { return isSignedIn() && exists(/databases/$(database)/documents/students/$(request.auth.uid)); }

    // Admins: full control of everything
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Profile collections: users can read their own profile; only admin writes
    match /admins/{id}   { allow read: if isSignedIn() && request.auth.uid == id; }
    match /teachers/{id} { allow read: if isSignedIn() && request.auth.uid == id; allow write: if isAdmin(); }
    match /students/{id} { allow read: if isSignedIn() && request.auth.uid == id; allow write: if isAdmin(); }

    // Course catalog & content: readable by any signed-in user, writable by admin/teacher of that course
    match /courses/{id}      { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /ebooks/{id}       { allow read: if isSignedIn(); allow create, update: if isAdmin() || isTeacher(); }
    match /handbooks/{id}    { allow read: if isSignedIn(); allow create, update: if isAdmin() || isTeacher(); }
    match /syllabus/{id}     { allow read: if isSignedIn(); allow create, update: if isAdmin() || isTeacher(); }
    match /materials/{id}    { allow read: if isSignedIn(); allow create, update: if isAdmin() || isTeacher(); }
    match /audio/{id}        { allow read: if isSignedIn(); allow create: if isAdmin() || isTeacher(); }
    match /videos/{id}       { allow read: if isSignedIn(); allow create: if isAdmin() || isTeacher(); }

    // Attendance: students create their own record, teachers/admin read
    match /attendance/{id} {
      allow create: if isStudent();
      allow read: if isAdmin() || isTeacher() || isStudent();
    }

    // Feedback & Questions
    match /feedback/{id}  { allow create: if isStudent(); allow read: if isAdmin() || isTeacher(); }
    match /questions/{id} {
      allow create: if isStudent();
      allow update: if isTeacher() || isAdmin();
      allow read: if isSignedIn();
    }

    // Exams & results
    match /examQuestions/{id} { allow read: if isStudent() || isTeacher() || isAdmin(); allow write: if isAdmin(); }
    match /results/{id} {
      allow create: if isStudent();
      allow read: if isSignedIn();
    }

    // Notifications & logs
    match /notifications/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /activityLogs/{id}  { allow create: if isSignedIn(); allow read: if isAdmin(); }
    match /settings/{id}      { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Live Class WebRTC signaling: any signed-in user may read (to see if a
    // class is live) or write (to exchange offer/answer/ICE candidates).
    match /liveSessions/{courseId} {
      allow read, write: if isSignedIn();
      match /viewers/{viewerId} {
        allow read, write: if isSignedIn();
        match /{sub=**} { allow read, write: if isSignedIn(); }
      }
    }
    match /analytics/{id}     { allow read, write: if isAdmin(); }
  }
}
